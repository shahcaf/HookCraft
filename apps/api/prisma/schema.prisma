generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String         @id @default(uuid())
  discordId     String         @unique
  username      String
  discriminator String
  avatar        String?
  email         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  webhooks      SavedWebhook[]
  drafts        Draft[]
  templates     Template[]
}

model SavedWebhook {
  id        String   @id @default(uuid())
  name      String
  url       String   // Encrypted
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Draft {
  id        String   @id @default(uuid())
  name      String
  message   String   // Discord webhook payload (JSON string)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Template {
  id          String   @id @default(uuid())
  name        String
  description String?
  message     String   // Discord webhook payload (JSON string)
  isPublic    Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
