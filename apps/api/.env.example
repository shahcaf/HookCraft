# Copy this file to .env and fill in your values

# Database
DATABASE_URL="postgresql://hookcraft:hookcraft@localhost:5432/hookcraft"

# Security
JWT_SECRET="change-me-to-a-long-random-string"
ENCRYPTION_KEY="32-byte-hex-key-change-in-production"

# Server
API_PORT=3001
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Redis (used for webhook send queue)
REDIS_URL="redis://localhost:6379"

# Discord OAuth2 - Create an app at https://discord.com/developers/applications
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_REDIRECT_URI="http://localhost:3001/auth/discord/callback"

# Discord Bot - Optional: used to auto-add users to your server on login
DISCORD_BOT_TOKEN="your-bot-token"
DISCORD_GUILD_ID="your-guild-id"
DISCORD_BOT_CLIENT_ID="your-bot-client-id"
DISCORD_BOT_CLIENT_SECRET="your-bot-client-secret"
DISCORD_BOT_REDIRECT_URI="http://localhost:3000/bot/callback"
