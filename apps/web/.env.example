# Discord Application Credentials
# Create an application at: https://discord.com/developers/applications
# In the OAuth2 settings, add the redirect URI: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID="your_client_id_here"
DISCORD_CLIENT_SECRET="your_client_secret_here"

# NextAuth Configuration
# Generate a secret by running: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Guild ID for checking VIP roles
# This is the actual ID of the server, NOT the invite code
# You can get it by right clicking the server icon -> "Copy Server ID" (requires Developer Mode enabled in Discord)
DISCORD_SUPPORT_GUILD_ID="YOUR_GUILD_ID_HERE"
