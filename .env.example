# ─────────────────────────────────────────────
# HookCraft — Environment Variables
# Copy to .env.local (web) and .env (api)
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL="postgresql://hookcraft:hookcraft@localhost:5432/hookcraft"

# ── Redis ─────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="100d"

# ── Discord OAuth2 ───────────────────────────
DISCORD_CLIENT_ID="1520998170656505856"
DISCORD_CLIENT_SECRET="CP3Tdal3MokDVOQ4LNtKH0pM7WjFTKuu"
DISCORD_REDIRECT_URI="http://localhost:3000/auth/discord/callback"

# ── Encryption (webhook URLs) ─────────────────
ENCRYPTION_KEY="32-byte-hex-key-change-in-production"

# ── App URLs ──────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
API_PORT=3001

# ── Session ───────────────────────────────────
SESSION_SECRET="change-me-session-secret"
